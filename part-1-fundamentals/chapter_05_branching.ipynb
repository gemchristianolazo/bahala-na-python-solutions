        "\n",
        "## 1. Write a store checker that prints one of three messages:\n",
        "\n",
        "- \"Sold out\"\n",
        "- \"Low stock\"\n",
        "- \"Stock is healthy\""
      ],
      "metadata": {
        "id": "JNvR7K3aFFZg"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "stock = 5\n",
        "\n",
        "if stock == 0:\n",
        "  print(\"Sold out\")\n",
        "elif stock < 5:\n",
        "  print(\"Low stock\")\n",
        "else:\n",
        "  print(\"Stock is healthy\")\n",
        "\n",
        "\n"
      ],
      "metadata": {
